{
  "name": "fui-skill",
  "version": "1.3.0",
  "description": "AI operating manual for FUI (Framework UI) low-code module development. Covers module.json authoring, action engine, UI layout system, component selection, tAPI SP design, MCP tool workflows, and publish safety protocols.",
  "activation_triggers": [
    "module", "module.json", "fui", "f-table", "f-dialog", "f-echart",
    "controls", "data", "watch", "CALL", "API", "CALLBACK", "OUT",
    "menuChucNang", "ctrl-update", "hidden-container",
    "spAPI_", "stored procedure", "tAPI",
    "session_set", "module_checkout", "module_publish"
  ],
  "context_loading": {
    "tier1_always": [
      "SKILL.md",
      "references/controls-patterns.md",
      "references/module-structure.md",
      "references/ui-patterns.md"
    ],
    "tier3_on_demand": {
      "component_selection": "references/components-input.md, references/components-display.md, references/components-dialog.md, references/component-table.md",
      "component_design": "references/component-design.md",
      "tapi_sp": "references/tapi-reference.md",
      "pdf_generation": "references/pdfmake.md",
      "advanced_scripting": "references/advanced-techniques.md",
      "watcher_patterns": "references/watcher-patterns.md",
      "tool_safety": "references/tools-registry.md",
      "definition_of_done": "references/verification.md",
      "templates": "references/ui-templates.md, examples/"
    }
  },
  "evals": {
    "directory": "evals/",
    "count": 8,
    "index": "evals/README.md",
    "scenarios": [
      { "id": "eval-01", "name": "Basic CRUD Module", "difficulty": "beginner" },
      { "id": "eval-02", "name": "Filter Toolbar + Cascading Watch", "difficulty": "beginner" },
      { "id": "eval-03", "name": "Chart / Report Module", "difficulty": "beginner" },
      { "id": "eval-04", "name": "Cross-window Data Exchange", "difficulty": "intermediate" },
      { "id": "eval-05", "name": "tAPI SP Design + FUI Wiring", "difficulty": "intermediate" },
      { "id": "eval-06", "name": "Inline CRUD with ctrl-update", "difficulty": "beginner" },
      { "id": "eval-07", "name": "Permission-gated UI", "difficulty": "beginner" },
      { "id": "eval-08", "name": "Multi-dialog + menuChucNang + TypeLoad", "difficulty": "advanced" }
    ]
  },
  "tool_safety": {
    "registry": "references/tools-registry.md",
    "default_stance": "RequiresConfirm",
    "destructive_tools": [
      "module_publish",
      "db_sp_deploy",
      "db_sp_delete",
      "db_sql_execute_nonquery",
      "file_import_delete"
    ],
    "mandatory_workflows": {
      "module_publish_staged": "module_preview → user approves → module_publish_staged",
      "db_sp_deploy": "show summary → explicit user confirmation → db_sp_deploy"
    }
  },
  "verification": {
    "checklist": "references/verification.md",
    "gates": ["module_structure", "action_correctness", "sp_naming", "component_api", "publish_workflow"]
  },
  "maintainer": "FUI MCP Team",
  "last_updated": "2026-05-31"
}
